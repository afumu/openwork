{
  "schemaVersion": 1,
  "name": "vite-react",
  "paramsSchema": {
    "type": "object",
    "properties": {
      "appName": {
        "type": "string",
        "default": "openwork-react-app",
        "pattern": "^[a-z0-9-]+$"
      },
      "port": {
        "type": "number",
        "default": 9000,
        "minimum": 1024,
        "maximum": 65535
      }
    },
    "additionalProperties": false
  },
  "commands": {
    "install": ["npm", "install"],
    "dev": ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "<%= port %>"],
    "build": ["npm", "run", "build"],
    "start": ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "<%= port %>"],
    "validate": ["npm", "run", "typecheck"]
  }
}
