{
  "schemaVersion": 1,
  "name": "vite-vue",
  "paramsSchema": {
    "type": "object",
    "properties": {
      "appName": {
        "type": "string",
        "default": "openwork-vue-app",
        "pattern": "^[a-z0-9-]+$"
      },
      "port": {
        "type": "number",
        "default": 9000,
        "minimum": 1024,
        "maximum": 65535
      }
    },
    "additionalProperties": false
  },
  "commands": {
    "install": ["npm", "install"],
    "dev": ["openwork", "vite-proxy", "--public-port", "<%= port %>", "--target-port", "<%= proxyTargetPort %>", "--base", "/proxy/<%= port %>/", "--", "npm", "run", "dev", "--", "--host", "127.0.0.1", "--port", "<%= proxyTargetPort %>"],
    "build": ["npm", "run", "build"],
    "start": ["openwork", "vite-proxy", "--public-port", "<%= port %>", "--target-port", "<%= proxyTargetPort %>", "--base", "/proxy/<%= port %>/", "--", "npm", "run", "preview", "--", "--host", "127.0.0.1", "--port", "<%= proxyTargetPort %>"],
    "validate": ["npm", "run", "typecheck"]
  }
}
