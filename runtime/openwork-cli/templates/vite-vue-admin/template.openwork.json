{
  "schemaVersion": 1,
  "name": "vite-vue-admin",
  "paramsSchema": {
    "type": "object",
    "properties": {
      "appName": {
        "type": "string",
        "default": "openwork-admin",
        "pattern": "^[a-z0-9-]+$"
      },
      "port": {
        "type": "number",
        "default": 9000,
        "minimum": 1024,
        "maximum": 65535
      }
    },
    "additionalProperties": false
  },
  "commands": {
    "install": ["pnpm", "install", "--prefer-frozen-lockfile", "--prefer-offline"],
    "dev": ["pnpm", "dev", "--host", "0.0.0.0", "--port", "<%= port %>"],
    "build": ["pnpm", "build"],
    "start": ["pnpm", "preview", "--host", "0.0.0.0", "--port", "<%= port %>"],
    "validate": ["pnpm", "typecheck"]
  }
}
